{
  "name": "music-player",
  "version": "1.3.0",
  "main": "dist-electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaomingky/XiaoMingKY163_Player"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "electron-updater": "^6.8.3",
    "flac-metadata": "^0.1.1",
    "flv.js": "^1.6.2",
    "lucide-vue-next": "^0.446.0",
    "music-metadata": "^11.12.3",
    "node-id3": "^0.2.9",
    "pinia": "^3.0.4",
    "sharp": "^0.34.5",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.8",
    "vite-plugin-electron": "^0.28.1",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.music.player",
    "productName": "茗韵时光",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron",
      "public",
      "package.json"
    ],
    "extraResources": [
      "font/**"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "茗韵时光"
    }
  }
}
